# =============================================================================
# Database - Local PostgreSQL (Docker)
# =============================================================================
# Primary database connection (used by Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insightai"

# Direct database connection (for special scenarios like connection pooling)
# DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insightai"

# =============================================================================
# AI API Configuration (OpenAI-compatible)
# =============================================================================
# API endpoint (e.g., Alibaba Cloud DashScope)
OPENAI_COMPATIBLE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# API Key
OPENAI_COMPATIBLE_API_KEY="sk-your-api-key-here"

# Chat model (optional, see default below)
# OPENAI_CHAT_MODEL="qwen3.5-plus-2026-04-20"

# Embedding model for vector search (optional, see default below)
# OPENAI_EMBEDDING_MODEL="text-embedding-v4"

# =============================================================================
# OpenAI API (for Agent workflow - Web Research & Report Generation)
# =============================================================================
# Required for Report Generation Agent (Research, Retrieval, Analysis, Writing)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# =============================================================================
# Stripe Configuration (for Subscription Management)
# =============================================================================
# Stripe secret key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."

# Stripe webhook secret (from https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (from https://dashboard.stripe.com/pricing)
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_TEAM="price_..."

# Public Stripe keys (for frontend)
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ID_TEAM="price_..."

# =============================================================================
# Object Storage (for video transcripts — Qiniu)
# =============================================================================
# Storage provider name (currently only "qiniu" is supported)
# VIDEO_STORAGE_PROVIDER="qiniu"
# QINIU_ACCESS_KEY="your-access-key"
# QINIU_SECRET_KEY="your-secret-key"
# QINIU_BUCKET="your-bucket-name"
# QINIU_DOMAIN="https://cdn.example.com"       # 公开访问域名（必须包含 http:// 或 https:// 前缀）
# QINIU_UPLOAD_URL="https://up-z2.qiniup.com"  # 服务端上传域名，根据 bucket 区域选择
#                                               # z0=华东, z1=华北, z2=华南, na0=北美, as0=新加坡, cn-east-2=华东2
#                                               # 客户端会根据此 URL 自动识别上传区域

# =============================================================================
# Application Environment (for storage path prefix)
# =============================================================================
# Used to separate uploaded files by environment (development | staging | production)
# Defaults to NODE_ENV if not set
# APP_ENV="development"

# =============================================================================
# Auth.js Configuration
# =============================================================================
# Secret key for encrypting sessions, JWT tokens, and CSRF tokens
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-at-least-16-characters"

# Application URL - used for generating callback links and cookie configuration
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# Optional: Node.js Environment
# =============================================================================
# NODE_ENV="development"
