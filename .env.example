# Database - Local PostgreSQL (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/insightai"

# AI API Configuration (OpenAI-compatible)
OPENAI_COMPATIBLE_BASE_URL=""
OPENAI_COMPATIBLE_API_KEY="sk-your-api-key-here"
OPENAI_CHAT_MODEL="qwen3.6-plus-2026-04-02"
OPENAI_EMBEDDING_MODEL="text-embedding-v4"

# Auth.js Secret - 用于加密 session、JWT token 和 CSRF token
AUTH_SECRET="your-auth-secret-here"

# Application URL - Auth.js 用它来生成回调链接和 cookie 配置
NEXTAUTH_URL="http://localhost:3000"
