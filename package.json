{
  "name": "insightai-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:status": "prisma migrate status",
    "db:deploy": "npm run db:generate && npm run db:migrate",
    "setup": "npm install && npm run db:generate && npm run db:push",
    "dev:up": "docker compose up -d --wait && npm run db:generate && npm run db:push && next dev",
    "dev:with-db": "docker compose up -d db && npm run db:generate && npm run db:push && next dev",
    "dev:clean": "npm run db:reset && next dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check": "npm run lint && npm run typecheck && npm run build",
    "check:ci": "npm run lint && npm run typecheck",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "build:analyze": "ANALYZE=true next build",
    "build:prod": "NODE_ENV=production npm run build",
    "start:prod": "NODE_ENV=production npm run start",
    "deploy": "npm run build:prod && npm run db:deploy",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "clean:all": "npm run clean && rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean:all && npm install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose restart",
    "docker:logs": "docker compose logs -f",
    "ci": "npm run check:ci && npm run test",
    "preview": "npm run build && npm run start",
    "reset": "npm run docker:down && npm run clean:all && npm run setup"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/react": "^1.2.12",
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.4.1",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.20.0",
    "ai": "^4.3.19",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "qiniu": "^7.15.2",
    "qiniu-js": "^3.4.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "prettier": "^3",
    "storybook": "^8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
